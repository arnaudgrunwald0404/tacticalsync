# App environment example
# Copy to .env.local (for local dev) or use CI secrets

# Supabase
VITE_SUPABASE_URL={{https://YOUR-PROJECT.ref.supabase.co}}
VITE_SUPABASE_ANON_KEY={{YOUR_SUPABASE_ANON_KEY}}
# Backward-compat (will be removed later):
# VITE_SUPABASE_PUBLISHABLE_KEY={{YOUR_SUPABASE_ANON_KEY}}

# Playwright / E2E (local dev)
PLAYWRIGHT_BASE_URL=http://localhost:5173

# Tests that require elevated access (helpers only; do NOT expose in client)
SUPABASE_SERVICE_ROLE_KEY={{YOUR_SERVICE_ROLE_KEY}}

# ClearGO AI API (for live 1:1 prep in Chief of Staff)
VITE_CLEARGO_API_URL=https://cleargo.netlify.app
VITE_CLEARGO_API_KEY=your-cleargo-api-key

# Google Calendar integration (Supabase Auth + edge functions).
# These are NOT VITE_ vars — they live as Supabase project/function secrets
# and are never shipped to the client:
#   supabase secrets set GOOGLE_CLIENT_ID=...
#   supabase secrets set GOOGLE_CLIENT_SECRET=...
# Consumed by:
#   - supabase/config.toml [auth.external.google] for the OAuth handshake
#   - functions/google-calendar-sync to refresh the user's access token

# Zoom OAuth integration (Chief of Staff → 1:1 prep).
# VITE_ZOOM_CLIENT_ID is the only client-side var — used to build the authorize URL.
VITE_ZOOM_CLIENT_ID=your-zoom-client-id
# Server-side secrets (set via `supabase secrets set`):
#   supabase secrets set ZOOM_CLIENT_ID=...
#   supabase secrets set ZOOM_CLIENT_SECRET=...
#   supabase secrets set ZOOM_REDIRECT_URI=https://your-domain.com/chief-of-staff?zoom=connected

# Slack OAuth integration (Chief of Staff → 1:1 prep & share).
# VITE_SLACK_CLIENT_ID is the only client-side var — used to build the authorize URL.
VITE_SLACK_CLIENT_ID=your-slack-client-id
# Server-side secrets (set via `supabase secrets set`):
#   supabase secrets set SLACK_CLIENT_ID=...
#   supabase secrets set SLACK_CLIENT_SECRET=...
#   supabase secrets set SLACK_REDIRECT_URI=https://your-domain.com/settings?section=slack-sync&slack=connected
# SLACK_SIGNING_SECRET verifies inbound Slack requests (slash commands +
# interactivity). Required by the slack-add-suggestion and agent-slack-action
# functions:
#   supabase secrets set SLACK_SIGNING_SECRET=...
# Slack app config → add a slash command (e.g. /add-to-my-lists) whose Request URL
# points at the slack-add-suggestion function:
#   https://<project-ref>.functions.supabase.co/slack-add-suggestion

# Google AI (Imagen 3) — for weekend banner image generation.
# Set as a Supabase function secret:
#   supabase secrets set GOOGLE_AI_API_KEY=...
# Get a key at https://aistudio.google.com/apikey
